{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "wifi: clean",
      "type": "shell",
      "command": "make clean",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": []
    },
    {
      "label": "wifi: test",
      "type": "shell",
      "command": "make test",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "wifi: check",
      "type": "shell",
      "command": "make check",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "wifi: build",
      "type": "shell",
      "command": "make build",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "wifi: flash(wlink)",
      "type": "shell",
      "command": "make flash",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "wifi: flash(openocd)",
      "type": "shell",
      "command": "make flash-openocd",
      "options": {
        "cwd": "${workspaceFolder}/2-wifi"
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
